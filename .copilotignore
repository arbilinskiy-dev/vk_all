# ═══════════════════════════════════════════════════════
#  .copilotignore — исключаем мусор из контекста Copilot
# ═══════════════════════════════════════════════════════
# Работает как .gitignore, но для AI.
# Файлы из этого списка НЕ попадут в контекст Copilot,
# что экономит токены и убирает шум.

# ─── Python-кэш и байткод ───
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Виртуальные окружения ───
.venv/
venv/
env/

# ─── Базы данных и бэкапы ───
*.db
*.db-journal
*.db.backup_*
backend_python/vk_planner.db*

# ─── Логи ───
*.log
npm-debug.log*
logs_sync.json
logs_sync.txt

# ─── Node modules и билды ───
node_modules/
dist/
dist-ssr/
*.local

# ─── Системные и редакторные файлы ───
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.idea/
driver.cab

# ─── Временные тест-скрипты (артефакты отладки) ───
backend_python/_check_alena*.py
backend_python/_diag*.py
backend_python/_test_fix.py
backend_python/test_decrypt*.py
backend_python/test_pilmoji.py
backend_python/test_proxy.py
